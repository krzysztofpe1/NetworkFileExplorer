<Window x:Class="NetworkFileExplorer.WpfApplication.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NetworkFileExplorer.WpfApplication"
        mc:Ignorable="d"
        Title="InputDialog" Height="450" Width="400">
    <Grid>
        <TextBox x:Name="fileNameBox" HorizontalAlignment="Left" Height="23" Margin="61,43,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="299"/>
        <Label Content="Name:" HorizontalAlignment="Left" Height="23" Margin="10,43,0,0" VerticalAlignment="Top" Width="51"/>
        <CheckBox x:Name="CB_R" Content="Read Only" HorizontalAlignment="Left" Height="24" Margin="61,115,0,0" VerticalAlignment="Top" Width="139"/>
        <CheckBox x:Name="CB_A" Content="Archive" HorizontalAlignment="Left" Height="24" Margin="61,144,0,0" VerticalAlignment="Top" Width="139"/>
        <CheckBox x:Name="CB_H" Content="Hidden" HorizontalAlignment="Left" Height="24" Margin="61,168,0,0" VerticalAlignment="Top" Width="139"/>
        <CheckBox x:Name="CB_S" Content="System" HorizontalAlignment="Left" Height="24" Margin="61,192,0,0" VerticalAlignment="Top" Width="139"/>
        <Button Content="OK" HorizontalAlignment="Left" Height="19" Margin="20,372,0,0" VerticalAlignment="Top" Width="79" Click="OK_Click"/>
        <Button Content="Cancel" HorizontalAlignment="Left" Height="19" Margin="121,372,0,0" VerticalAlignment="Top" Width="79" Click="Cancel_Click"/>
        <RadioButton x:Name="radioFile" Content="File" HorizontalAlignment="Left" Height="18" Margin="36,81,0,0" VerticalAlignment="Top" Width="47" IsChecked="True"/>
        <RadioButton x:Name="radioDir" Content="Directory" HorizontalAlignment="Left" Height="18" Margin="83,81,0,0" VerticalAlignment="Top" Width="112"/>

    </Grid>
</Window>
