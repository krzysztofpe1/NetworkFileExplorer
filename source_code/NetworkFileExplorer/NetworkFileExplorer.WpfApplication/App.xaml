<Application x:Class="NetworkFileExplorer.WpfApplication.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:NetworkFileExplorer.WpfApplication"
             xmlns:utils="clr-namespace:NetworkFileExplorer.WpfApplication.Utils"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ObjectDataProvider x:Key="Strings"
             ObjectType="{x:Type utils:CultureResourcesHelper}"
             MethodName="GetStringsInstance" />
    </Application.Resources>

</Application>
